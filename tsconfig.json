{
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src",
    "target": "ES2023",
    "module": "ESNext",
    "declaration": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,

    /* Bundler mode */
    "isolatedModules": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
