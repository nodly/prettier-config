{
  "name": "@nodly/prettier-config",
  "type": "module",
  "version": "5.2.6",
  "description": "A shareable configuration for prettier.",
  "author": "Nodly AB",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodly/prettier-config.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "main": "./dist/prettier.config.cjs",
  "module": "./dist/prettier.config.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/prettier.config.js",
      "require": "./dist/prettier.config.cjs"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "prettier-plugin-tailwindcss": "^0.7.4"
  },
  "devDependencies": {
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.2.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/node": "22.19.2",
    "pinst": "3.0.0",
    "prettier": "3.7.4",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3",
    "vite": "7.2.7",
    "vite-plugin-dts": "4.5.4"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
