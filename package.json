{
  "name": "@nodly/prettier-config",
  "type": "module",
  "version": "6.0.0",
  "description": "A shareable configuration for prettier.",
  "author": "Nodly AB",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodly/prettier-config.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "main": "./dist/prettier.config.js",
  "module": "./dist/prettier.config.js",
  "types": "./dist/prettier.config.d.ts",
  "exports": {
    ".": {
      "import": "./dist/prettier.config.js",
      "types": "./dist/prettier.config.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/node": "25.9.0",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
